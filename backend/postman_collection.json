{
  "info": {
    "name": "SD COLLECTIONS API",
    "description": "Complete API collection for the SD COLLECTIONS eCommerce backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5253/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "couponId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "reviewId", "value": "" },
    { "key": "bannerId", "value": "" },
    { "key": "addressId", "value": "" }
